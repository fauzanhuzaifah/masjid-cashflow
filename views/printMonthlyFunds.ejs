<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Laporan Keuangan Bulanan</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @media print { body { margin: 0; } .no-print { display: none; } }
        body { font-family: 'Inter', sans-serif; font-size: 12pt; background-color: #fff; }
        .paper { width: 21cm; padding: 2cm; margin: 0 auto; }
        h3, h4 { text-align: center; margin-bottom: 5px; }
        hr { border: 2px solid #000; margin-bottom: 30px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        th, td { border: 1px solid #000; padding: 8px; }
        th { background-color: #f0f0f0; text-align: center; font-weight: bold; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .section-title { font-weight: bold; font-size: 14pt; margin-bottom: 10px; }
    </style>
</head>
<body>

<div class="paper">
    <h3>LAPORAN KEUANGAN KONSOLIDASI</h3>
    <h4>MASJID ISTIKLAL OSAKA</h4>
    <p style="text-align:center; margin-bottom:20px;">Periode : <%= month %> <%= year %></p>
    <hr>

    <!-- 1. ZAKAT -->
    <div class="section-title">1. DANA ZAKAT</div>
    <table>
        <thead><tr><th width="10%">No</th><th width="60%">Uraian</th><th width="30%">Jumlah (¥)</th></tr></thead>
        <tbody>
            <tr><td class="text-center">1</td><td>Pemasukan Zakat Bulan Ini</td><td class="text-right"><%= Number(zakat.in).toLocaleString('ja-JP') %></td></tr>
            <tr><td class="text-center">2</td><td>Pengeluaran Zakat Bulan Ini</td><td class="text-right">(<%= Number(zakat.out).toLocaleString('ja-JP') %>)</td></tr>
            <tr style="font-weight: bold; background-color: #e8e8e8;"><td colspan="2" class="text-center">SALDO AKHIR DANA ZAKAT</td><td class="text-right"><%= Number(zakat.balance).toLocaleString('ja-JP') %></td></tr>
        </tbody>
    </table>

    <!-- 2. WAKAF -->
    <div class="section-title">2. DANA WAKAF</div>
    <table>
        <thead><tr><th>No</th><th>Uraian</th><th>Jumlah (¥)</th></tr></thead>
        <tbody>
            <tr><td class="text-center">1</td><td>Pemasukan Wakaf Bulan Ini</td><td class="text-right"><%= Number(wakaf.in).toLocaleString('ja-JP') %></td></tr>
            <tr><td class="text-center">2</td><td>Pengeluaran Pembangunan Bulan Ini</td><td class="text-right">(<%= Number(wakaf.out).toLocaleString('ja-JP') %>)</td></tr>
            <tr style="font-weight: bold; background-color: #e8e8e8;"><td colspan="2" class="text-center">SALDO AKHIR DANA WAKAF</td><td class="text-right"><%= Number(wakaf.balance).toLocaleString('ja-JP') %></td></tr>
        </tbody>
    </table>

    <!-- 3. OPERASIONAL -->
    <div class="section-title">3. DANA OPERASIONAL (Infaq, Sedekah, Usaha)</div>
    <table>
        <thead><tr><th>No</th><th>Uraian</th><th>Jumlah (¥)</th></tr></thead>
        <tbody>
            <tr><td class="text-center">1</td><td>Pemasukan Operasional Bulan Ini</td><td class="text-right"><%= Number(operational.in).toLocaleString('ja-JP') %></td></tr>
            <tr><td class="text-center">2</td><td>Pengeluaran Rutin Bulan Ini</td><td class="text-right">(<%= Number(operational.out).toLocaleString('ja-JP') %>)</td></tr>
            <tr style="font-weight: bold; background-color: #e8e8e8;"><td colspan="2" class="text-center">SURPLUS / (DEFISIT) BULAN INI</td><td class="text-right"><%= Number(operational.balance).toLocaleString('ja-JP') %></td></tr>
        </tbody>
    </table>

    <!-- 4. REKAPITULASI -->
    <div class="section-title">4. REKAPITULASI KESELURUHAN</div>
    <table>
        <thead><tr><th>No</th><th>Uraian</th><th>Jumlah (¥)</th></tr></thead>
        <tbody>
            <tr><td class="text-center">1</td><td>Total Pemasukan Keseluruhan</td><td class="text-right"><%= Number(aggregate.totalInMonth).toLocaleString('ja-JP') %></td></tr>
            <tr><td class="text-center">2</td><td>Total Pengeluaran Keseluruhan</td><td class="text-right">(<%= Number(aggregate.totalOutMonth).toLocaleString('ja-JP') %>)</td></tr>
            <tr style="font-weight: bold; background-color: #d1ecf1;"><td colspan="2" class="text-center">SALDO KAS MASJID</td><td class="text-right"><%= Number(aggregate.totalBalance).toLocaleString('ja-JP') %></td></tr>
        </tbody>
    </table>

    <!-- TANDA TANGAN -->
    <div style="margin-top: 50px; width: 50%; float: right; text-align: center;">
        <p>Osaka, <%= new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) %></p>
        <br><br><br><br>
        <p><u>Ketua Masjid Istiqlal Osaka</u></p>
    </div>

    <div class="no-print text-center mt-5">
        <button onclick="window.print()" class="btn btn-primary">Cetak</button>
    </div>
</div>
</body>
</html>