<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Monitoring Dana - SI-MIO</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; font-family: 'Inter', sans-serif; }
        .card { border: none; border-radius: 15px; box-shadow: 0 10px 30px 0 rgba(0, 0, 0, 0.05); }
        .btn { border-radius: 8px; font-weight: 500; border: none; }
    </style>
</head>
<body class="bg-body">
    <nav class="navbar navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">SI-MIO</a>
            <div class="d-flex align-items-center gap-2">
                <a href="/dashboard" class="btn btn-light btn-sm">Dashboard</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">Monitoring Dana Masjid</h2>

        <!-- Form Cetak Laporan -->
        <div class="card shadow mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Cetak Laporan Konsolidasi Bulanan</h5>
            </div>
            <div class="card-body">
                <form action="/report/print-monthly-funds" method="GET" target="_blank">
                    <div class="row align-items-end">
                        <div class="col-md-4 mb-2">
                            <label>Pilih Bulan</label>
                            <select name="month" class="form-select" required>
                                <% 
                                const months = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
                                const currentMonth = new Date().getMonth() + 1;
                                for(let i=1; i<=12; i++) { %>
                                    <option value="<%= i %>" <%= i == currentMonth ? 'selected' : '' %>><%= months[i-1] %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label>Pilih Tahun</label>
                            <select name="year" class="form-select" required>
                                <% 
                                const currentYear = new Date().getFullYear();
                                for(let y = currentYear - 2; y <= currentYear + 1; y++) { %>
                                    <option value="<%= y %>" <%= y == currentYear ? 'selected' : '' %>><%= y %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <button type="submit" class="btn btn-success w-100">Cetak Laporan PDF</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Data Saldo -->
        <div class="row">
            <!-- Zakat -->
            <div class="col-md-6 mb-4">
                <div class="card shadow h-100">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">Dana Zakat</h4>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td>Total Pemasukan</td>
                                <td class="text-end text-success fw-bold">¥ <%= Number(zakat.in).toLocaleString('ja-JP') %></td>
                            </tr>
                            <tr>
                                <td>Total Pengeluaran</td>
                                <td class="text-end text-danger fw-bold">¥ <%= Number(zakat.out).toLocaleString('ja-JP') %></td>
                            </tr>
                            <tr class="border-top">
                                <td class="fw-bold">Sisa Saldo Dana Zakat</td>
                                <td class="text-end fw-bold">¥ <%= Number(zakat.balance).toLocaleString('ja-JP') %></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Wakaf -->
            <div class="col-md-6 mb-4">
                <div class="card shadow h-100">
                    <div class="card-header bg-info text-white">
                        <h4 class="mb-0">Dana Wakaf</h4>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td>Total Pemasukan</td>
                                <td class="text-end text-success fw-bold">¥ <%= Number(wakaf.in).toLocaleString('ja-JP') %></td>
                            </tr>
                            <tr>
                                <td>Total Pengeluaran (Pembangunan)</td>
                                <td class="text-end text-danger fw-bold">¥ <%= Number(wakaf.out).toLocaleString('ja-JP') %></td>
                            </tr>
                            <tr class="border-top">
                                <td class="fw-bold">Sisa Saldo Dana Wakaf</td>
                                <td class="text-end fw-bold">¥ <%= Number(wakaf.balance).toLocaleString('ja-JP') %></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Operasional -->
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Dana Operasional (Infaq, Sedekah, Usaha)</h4>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-4 border-end">
                                <small class="text-muted">Sumber Dana Operasional</small>
                                <h3 class="text-success">¥ <%= Number(operational.in).toLocaleString('ja-JP') %></h3>
                                <small class="text-muted">*Dari Infaq, Sedekah, Usaha</small>
                            </div>
                            <div class="col-md-4 border-end">
                                <small class="text-muted">Beban Operasional</small>
                                <h3 class="text-danger">¥ <%= Number(operational.out).toLocaleString('ja-JP') %></h3>
                                <small class="text-muted">*Listrik, Air, Kegiatan, dll</small>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted">Sisa Saldo Operasional</small>
                                <% if (operational.balance < 0) { %>
                                    <h3 class="text-danger">¥ <%= Number(operational.balance).toLocaleString('ja-JP') %></h3>
                                    <div class="alert alert-danger p-1 mt-2 mb-0 small">
                                        <strong>⚠️ PERINGATAN: DEFISIT!</strong> Dana operasional tidak mencukupi untuk menutupi pengeluaran rutin.
                                    </div>
                                <% } else { %>
                                    <h3 class="text-success">¥ <%= Number(operational.balance).toLocaleString('ja-JP') %></h3>
                                    <small class="text-muted">*Dana Bebas/Tidak Terikat</small>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Catatan -->
        <div class="alert alert-warning shadow-sm">
            <h5 class="alert-heading"><strong>Catatan Penting untuk Admin:</strong></h5>
            <hr>
            <ul class="mb-0">
                <li><strong>Dana Zakat:</strong> Hanya boleh digunakan untuk kategori "Pengeluaran Zakat" (sesuai 8 asnaf).</li>
                <li><strong>Dana Wakaf:</strong> Hanya boleh digunakan untuk kategori "Pembangunan Masjid" (aset tetap).</li>
                <li><strong>Dana Operasional:</strong> Merupakan dana umum dari Infaq/Sedekah/Usaha, digunakan untuk kebutuhan rutin (Listrik, Air, dll).</li>
                <li>Pastikan memilih <strong>Kategori yang benar</strong> setiap kali input transaksi agar laporan monitoring ini akurat.</li>
            </ul>
        </div>

    </div>
</body>
</html>