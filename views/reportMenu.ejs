<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Menu Laporan - SI-MIO</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; font-family: 'Inter', sans-serif; }
        .card { border: none; border-radius: 15px; box-shadow: 0 10px 30px 0 rgba(0, 0, 0, 0.05); }
        .btn { border-radius: 8px; font-weight: 500; }
    </style>
</head>
<body class="bg-body">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">SI-MIO</a>
            <div class="d-flex align-items-center gap-2">
                <a href="/dashboard" class="btn btn-light btn-sm">Dashboard</a>
                <a href="/funds-monitoring" class="btn btn-outline-info btn-sm">Monitoring Dana</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">Menu Laporan</h2>

        <div class="card shadow">
            <div class="card-header">
                <h4 class="mb-0">Cetak Laporan Spesifik Bulanan</h4>
            </div>
            <div class="card-body">
                <form action="/report/print-specific" method="GET" target="_blank">
                    <div class="row mb-3">
                        <div class="col-md-3 mb-2">
                            <label>Pilih Jenis Dana</label>
                            <select name="category_id" class="form-select" required>
                                <option value="" disabled selected>-- Pilih Kategori --</option>
                                <optgroup label="Pemasukan">
                                    <% categories.forEach(cat => { %>
                                        <% if (cat.type === 'income') { %>
                                            <option value="<%= cat.id %>"><%= cat.name %></option>
                                        <% } %>
                                    <% }) %>
                                </optgroup>
                                <optgroup label="Pengeluaran">
                                    <% categories.forEach(cat => { %>
                                        <% if (cat.type === 'expense') { %>
                                            <option value="<%= cat.id %>"><%= cat.name %></option>
                                        <% } %>
                                    <% }) %>
                                </optgroup>
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label>Bulan</label>
                            <select name="month" class="form-select">
                                <% for(let i=1; i<=12; i++) { 
                                    const months = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
                                %>
                                    <option value="<%= i %>" <%= i == currentMonth ? 'selected' : '' %>><%= months[i-1] %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label>Tahun</label>
                            <select name="year" class="form-select">
                                <% years.forEach(y => { %>
                                    <option value="<%= y %>" <%= y == currentYear ? 'selected' : '' %>><%= y %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3 mb-2 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-success flex-grow-1">Cetak Laporan (PDF)</button>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end">
                         <button type="submit" class="btn btn-primary" formaction="/report/export-excel">Export ke Excel (.xlsx)</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>