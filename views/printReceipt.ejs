<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kwitansi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Pengaturan Kertas A5 Portrait */
        @page {
            size: A5 portrait; /* Ukuran setengah A4 */
            margin: 10mm;
        }
        body {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-family: 'Arial', sans-serif;
            font-size: 12pt;
        }
        @media print {
            .no-print { display: none; }
            body { margin: 0; padding: 0; }
        }
        @media screen {
            body { background-color: #eee; padding: 20px; }
            .paper {
                background-color: #fff;
                width: 14.8cm; /* Lebar A5 */
                height: 21cm;  /* Tinggi A5 */
                margin: 0 auto;
                padding: 1.5cm;
                box-shadow: 0 0 10px rgba(0,0,0,0.1);
            }
        }
        
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        
        .header-kwitansi {
            border-bottom: 2px solid #000;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .title-kwitansi {
            font-size: 18pt;
            font-weight: bold;
            letter-spacing: 2px;
            text-decoration: underline;
            margin-top: 5px;
        }
        
        .table-info {
            width: 100%;
            border-collapse: collapse;
        }
        .table-info td {
            padding: 5px 0;
            vertical-align: top;
        }
        .table-info .label {
            width: 30%;
        }
        
        .box-nominal {
            border: 2px solid #000;
            padding: 10px;
            margin-top: 10px;
            background-color: #f9f9f9;
        }
        
         .footer-kwitansi {
            margin-top: 60px; /* Ruang untuk tanda tangan */
            width: 50%;
            float: right;
            text-align: center;
        }
        
        /* TAMBAHKAN KODE INI */
        .footer-kwitansi p {
            margin: 0;
            margin-bottom: 0px; /* Jarak antara Tanggal ke Nama (dalam pixel) */
        }
    </style>
</head>
<body>

<div class="paper">
    <!-- Header -->
    <div class="header-kwitansi text-center">
        <h3>MASJID ISTIQLAL OSAKA</h3> <!-- Nama Masjid bisa diganti -->
        <p style="margin:0; font-size: 10pt;">1 Chome-2-10 Nakahiraki, Nishinari Ward, Osaka,557-0022, Japan</p>
        <p style="margin:0; font-size: 10pt;">Office Call number: +81 80-4844-7883</p>
        <div class="title-kwitansi">KWITANSI</div>
        <small>No: <%= transaction.id %>/KWT/<%= new Date(transaction.date).getFullYear() %></small>
    </div>

    <!-- Info Transaksi -->
    <table class="table-info">
        <tr>
            <td class="label">Telah terima dari</td>
            <td>: <strong><%= transaction.donor_name || 'Hamba Allah' %></strong></td>
        </tr>
        <tr>
            <td>Tanggal</td>
            <td>: <%= new Date(transaction.date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
        </tr>
        <tr>
            <td>Untuk Pembayaran</td>
            <td>: <strong><%= transaction.category_name.toUpperCase() %></strong></td>
        </tr>
        <tr>
            <td>Keterangan</td>
            <td>: <%= transaction.description || '-' %></td>
        </tr>
    </table>

    <!-- Nominal -->
    <div class="box-nominal text-center">
        <h4 class="mb-1">Nominal</h4>
        <h2 class="mb-0">
            ¥ <%= Number(transaction.amount).toLocaleString('ja-JP') %>
        </h2>
    </div>

        <!-- Tanda Tangan -->
    <div class="footer-kwitansi">
        <p><%= new Date().toLocaleDateString('id-ID', { locale:'id', day: 'numeric', month: 'long', year: 'numeric' }) %></p>
        <br><br><br>
        <p><u>Imam Masjid Istiqlal Osaka</u></p>
        
    </div>

    <!-- Tombol Print Layar -->
    <div class="no-print text-center mt-5">
        <button onclick="window.print()" class="btn btn-primary">Cetak Kwitansi</button>
    </div>
</div>

</body>
</html>